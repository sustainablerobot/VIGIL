# VIGIL Environment Configuration
# ================================
# Set your Anthropic API key here for live Claude explanations and incident reports.
# Without this key, VIGIL uses high-quality template fallbacks (still fully functional).
# 
# Get your key at: https://console.anthropic.com/
#
ANTHROPIC_API_KEY= "your_key_here"

# Optional: adjust simulation speed (default 1.0 = real-time, 0.2 = 5x faster for demos)
VIGIL_TICK_INTERVAL=1.0
